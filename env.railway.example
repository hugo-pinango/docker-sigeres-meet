################################################################################
# Plantilla de variables de entorno para desplegar Jitsi Meet en Railway.
#
# IMPORTANTE: SUBIR ESTE REPO NO BASTA
# Railway no auto-crea servicios desde Dockerfiles en subcarpetas (eso solo
# ocurre con monorepos JS). Hay que crear los 4 servicios MANUALMENTE la
# primera vez. Despues, cada push/PR despliega automaticamente.
#
# COMO USAR (primera vez)
# 1. Genera contrasenas fuertes:  ./railway/gen-passwords.sh
#    El script imprime los valores listos para pegar en Railway.
# 2. Crea un proyecto Railway y conectalo a este repo de GitHub.
# 3. Crea 4 servicios. Para CADA uno:
#       Settings -> Source -> Root Directory:    railway/<servicio>
#       Settings -> Config-as-Code -> Path:      /railway/<servicio>/railway.json
#    (Detalle critico: el "Config-as-Code Path" NO sigue al Root Directory,
#     hay que dar la ruta absoluta desde la raiz del repo. Ver:
#     https://docs.railway.com/deployments/monorepo)
# 4. En Project -> Variables (Shared Variables) carga las marcadas [SHARED].
#    En cada servicio carga su bloque especifico de Variables.
# 5. En el servicio "web": Settings -> Networking -> Generate Domain.
#    Pega ese URL en PUBLIC_URL (Shared Variables).
# 6. Despliega en orden: prosody -> jicofo -> jvb -> web.
#
# NETWORKING PRIVADO DE RAILWAY (IPv6 ONLY)
# La red privada de Railway es **IPv6 unicamente**. Las imagenes Jitsi
# escuchan por defecto en 0.0.0.0 (IPv4). Si un servicio no responde a
# otro por hostname, anade ENABLE_IPV6=1 (ya esta abajo) y verifica que
# el puerto bindeado acepta [::]. Si no, hay que parchear la config Lua
# de Prosody (interfaces "*") via volumen.
#
# Cada servicio tiene un hostname interno: ${RAILWAY_PRIVATE_DOMAIN}.
# Para referenciar otro servicio desde otro usa:
#   ${{prosody.RAILWAY_PRIVATE_DOMAIN}}
# Railway expande esa sintaxis al inyectar las variables al contenedor.
################################################################################


################################################################################
# [SHARED] Variables comunes a TODOS los servicios
################################################################################

# Zona horaria
TZ=America/Caracas

# Habilitar binding IPv6 (necesario para hablar entre servicios en Railway,
# cuya red privada es IPv6 only).
ENABLE_IPV6=1

# Dominio publico del frontend (sin trailing slash). En Railway se obtiene del
# servicio "web" via Settings -> Networking. Ej: https://meet-prod.up.railway.app
PUBLIC_URL=https://CHANGE-ME.up.railway.app

# Dominios XMPP internos (no cambiar a menos que sepas lo que haces)
XMPP_DOMAIN=meet.jitsi
XMPP_AUTH_DOMAIN=auth.meet.jitsi
XMPP_GUEST_DOMAIN=guest.meet.jitsi
XMPP_MUC_DOMAIN=muc.meet.jitsi
XMPP_INTERNAL_MUC_DOMAIN=internal-muc.meet.jitsi
XMPP_RECORDER_DOMAIN=recorder.meet.jitsi

# Hostname/puerto del servidor XMPP (Prosody) en la red privada de Railway.
# Sustituye prosody.RAILWAY_PRIVATE_DOMAIN por el nombre real del servicio.
XMPP_SERVER=${{prosody.RAILWAY_PRIVATE_DOMAIN}}
XMPP_BOSH_URL_BASE=http://${{prosody.RAILWAY_PRIVATE_DOMAIN}}:5280
XMPP_PORT=5222

# MUCs de orquestacion (no cambiar)
JVB_BREWERY_MUC=jvbbrewery
JIBRI_BREWERY_MUC=jibribrewery
JIGASI_BREWERY_MUC=jigasibrewery
JIBRI_RECORDER_USER=recorder
JIBRI_XMPP_USER=jibri
JVB_AUTH_USER=jvb
JIGASI_XMPP_USER=jigasi
JIGASI_TRANSCRIBER_USER=transcriber

# === SECRETOS (genera con railway/gen-passwords.sh) =============================
# CADA UNO debe ser distinto y de >=24 caracteres. NO uses los valores de ejemplo.
JICOFO_AUTH_PASSWORD=__GENERAR__
JVB_AUTH_PASSWORD=__GENERAR__
JICOFO_COMPONENT_SECRET=__GENERAR__
JIBRI_RECORDER_PASSWORD=__GENERAR__
JIBRI_XMPP_PASSWORD=__GENERAR__
JIGASI_XMPP_PASSWORD=__GENERAR__
JIGASI_TRANSCRIBER_PASSWORD=__GENERAR__


################################################################################
# Servicio: web   (railway/web)
################################################################################
# Aplica todas las variables [SHARED] mas las siguientes:

# Railway expone el contenedor en HTTPS automaticamente; deshabilitamos el TLS
# interno y dejamos que Railway termine TLS en su edge.
DISABLE_HTTPS=1
ENABLE_HTTP_REDIRECT=0
ENABLE_LETSENCRYPT=0

# Se usa el dominio del servicio "web" como PUBLIC_URL (ya esta arriba).
# Nginx interno escuchara en 80; Railway lo mapea al puerto publico.

# Funciones recomendadas
ENABLE_XMPP_WEBSOCKET=1
ENABLE_COLIBRI_WEBSOCKET=1
ENABLE_BREAKOUT_ROOMS=1
ENABLE_LOBBY=1
ENABLE_PREJOIN_PAGE=1


################################################################################
# Servicio: prosody   (railway/prosody)
################################################################################
# Aplica todas las variables [SHARED] mas las siguientes:

PROSODY_HTTP_PORT=5280
ENABLE_XMPP_WEBSOCKET=1
ENABLE_AV_MODERATION=1
ENABLE_BREAKOUT_ROOMS=1
ENABLE_LOBBY=1

# Autenticacion: "internal" requiere crear cuentas; deja vacio para conferencias
# anonimas (cualquiera con el link puede entrar).
# AUTH_TYPE=internal
# ENABLE_AUTH=1
# ENABLE_GUESTS=1


################################################################################
# Servicio: jicofo   (railway/jicofo)
################################################################################
# Aplica todas las variables [SHARED] mas las siguientes:

ENABLE_AUTO_OWNER=1
JICOFO_ENABLE_HEALTH_CHECKS=1
# Memoria max para la JVM de Jicofo (ajusta segun el plan de Railway)
JICOFO_MAX_MEMORY=1024m


################################################################################
# Servicio: jvb   (railway/jvb)
################################################################################
# Aplica todas las variables [SHARED] mas las siguientes:

# === ATENCION: UDP en Railway ===============================================
# JVB necesita UDP/10000 publico para enviar streams WebRTC al navegador.
# Railway NO expone UDP publico en planes estandar. Opciones:
#   A) Forzar TCP por puerto 443 (calidad reducida, latencia mayor):
#         JVB_TCP_HARVESTER_DISABLED=false
#         JVB_TCP_PORT=443
#         JVB_DISABLE_STUN=true
#      Y configurar Railway TCP Proxy en el puerto 443 del servicio jvb.
#   B) Usar TURN externo (coturn en VPS) y dejar JVB sin IP publica.
#   C) Mover JVB fuera de Railway (recomendado para produccion).
# ============================================================================

JVB_PORT=10000
JVB_BREWERY_MUC=jvbbrewery
JVB_AUTH_USER=jvb
# DOCKER_HOST_ADDRESS / JVB_ADVERTISE_IPS: IP publica que el JVB anunciara a
# los clientes para recibir UDP. En Railway no hay IP publica directa; deja
# vacio si vas a usar TCP/443 (opcion A) o pon la IP del VPS si usas opcion C.
# JVB_ADVERTISE_IPS=

# Memoria max para la JVM
VIDEOBRIDGE_MAX_MEMORY=2048m

# Endpoint XMPP del bridge (ya viene de [SHARED]: XMPP_SERVER, XMPP_PORT)
